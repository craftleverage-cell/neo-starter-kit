{
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(python *.py)",
      "Bash(python -m *)",
      "Bash(python3 *.py)",
      "Bash(python3 -m *)",
      "Bash(pip *)",
      "Bash(brew --version *)",
      "Bash(ffmpeg *)",
      "Task(*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch -*)",
      "Bash(git remote -v)",
      "Bash(git remote show *)",
      "Bash(git ls-files*)",
      "Bash(git check-ignore*)",
      "Bash(git rev-parse*)",
      "Bash(git config --list)",
      "Bash(git config --get *)",
      "Bash(git switch *)",
      "Bash(git stash)",
      "Bash(git stash list)",
      "Bash(git stash pop)",
      "Bash(git stash push *)",
      "Bash(git stash show *)",
      "Bash(git add *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./secrets/**)",
      "Read({{HOME}}/**/.env)",
      "Read({{HOME}}/**/.env.*)",
      "Read({{HOME}}/**/secrets/**)",
      "Edit({{HOME}}/.zshrc)",
      "Edit({{HOME}}/.zprofile)",
      "Edit({{HOME}}/.bash_profile)",
      "Edit({{HOME}}/.gitconfig)",
      "Edit({{HOME}}/.ssh/*)",
      "Edit(./.git/hooks/*)",
      "Edit({{HOME}}/.claude/hooks/**)",
      "Write({{HOME}}/.zshrc)",
      "Write({{HOME}}/.zprofile)",
      "Write({{HOME}}/.bash_profile)",
      "Write({{HOME}}/.gitconfig)",
      "Write({{HOME}}/.ssh/*)",
      "Write(./.git/hooks/*)",
      "Write({{HOME}}/Library/LaunchAgents/*)",
      "Edit({{HOME}}/Library/LaunchAgents/*)",
      "Write({{HOME}}/.claude/hooks/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git config *credential*)",
      "Bash(git config *core.hooksPath*)",
      "Bash(git add .)",
      "Bash(git add -A)",
      "Bash(git add --all)",
      "Bash(git push --force-with-lease *)",
      "Bash(git filter-branch *)",
      "Bash(git filter-repo *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(pip install *)",
      "Bash(pip uninstall *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(brew install *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(source *)",
      "Bash(npx *)",
      "Bash(uv *)",
      "Bash(gh api -X *)",
      "mcp__Claude_in_Chrome__javascript_tool",
      "Edit({{HOME}}/.claude/settings.json)",
      "Edit({{HOME}}/.claude/settings.local.json)",
      "Write({{HOME}}/.claude/settings.json)",
      "Write({{HOME}}/.claude/settings.local.json)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git commit *)",
      "Bash(git checkout -- *)",
      "Bash(git rm *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear)",
      "Bash(git tag *)",
      "Bash(git init *)",
      "Bash(gh repo create *)",
      "Bash(gh repo delete *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/pre-bash-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/audit-log.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|Agent|Skill|TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/vault-activity-log.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/vault-daily-summary.sh",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{HOME}}/.claude/hooks/vault-project-sync.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "outputStyle": "Neo",
  "defaultMode": "acceptEdits",
  "mcpServers": {
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "obsidian-mcp",
        "{{VAULT_PATH}}"
      ]
    }
  }
}
